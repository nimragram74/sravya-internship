# Supabase cloud sync (optional).
# The app works fully WITHOUT these — progress saves to the browser (localStorage).
# Add these to enable syncing progress across devices.
#
# 1. Create a free project at https://supabase.com
# 2. Run supabase/schema.sql in the Supabase SQL Editor
# 3. Copy Project URL + anon public key from Project Settings -> API
# 4. Copy this file to ".env" and paste the values below
#
# On Vercel, add these same two variables under Project Settings -> Environment Variables.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
